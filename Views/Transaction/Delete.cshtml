Delete


@model ELibrary.Models.Transaction

<h2>Delete Transaction</h2>

<h4>Are you sure you want to delete this transaction?</h4>
<div>
    <dl class="row">
        <dt class="col-sm-2">Book</dt>
        <dd class="col-sm-10">@Model.Book?.Title</dd>

        <dt class="col-sm-2">Member</dt>
        <dd class="col-sm-10">@Model.Member?.FullName</dd>

        <dt class="col-sm-2">Issued Date</dt>
        <dd class="col-sm-10">@Model.IssuedDate.ToShortDateString()</dd>

        <dt class="col-sm-2">Return Date</dt>
        <dd class="col-sm-10">@Model.ReturnDate?.ToShortDateString() ?? "Not Returned"</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
