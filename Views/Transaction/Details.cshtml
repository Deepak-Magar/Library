@model ELibrary.Models.Transaction

@{
    ViewData["Title"] = "Transaction Details";
}

<h2>@ViewData["Title"]</h2>

<div>
    <dl class="row">
        <dt class="col-sm-2">Book</dt>
        <dd class="col-sm-10">@Model.BookTitle</dd>

        <dt class="col-sm-2">Member</dt>
        <dd class="col-sm-10">@Model.MemberName</dd>

        <dt class="col-sm-2">Borrowed</dt>
        <dd class="col-sm-10">@Model.IssuedDate.ToShortDateString()</dd>

        <dt class="col-sm-2">Returned</dt>
        <dd class="col-sm-10">
            @(Model.ReturnDate.HasValue? Model.ReturnDate.Value.ToShortDateString() : "Not Returned")
        </dd>
    </dl>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
